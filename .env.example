# Backend database
# Use Neon pooled connection URL for application requests.
DATABASE_URL=postgresql+psycopg://jobagent:jobagent@localhost:5432/jobagent

# Use Neon direct connection URL for Alembic migrations.
# Locally this can be omitted because DATABASE_URL is used as the fallback.
DATABASE_URL_UNPOOLED=

# Frontend / API URLs
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Comma-separated frontend origins allowed to call the backend.
CORS_ORIGINS=http://localhost:3000

# Analysis provider: mock or openai
ANALYSIS_PROVIDER=mock

# Protects paid analysis requests; this is not the OpenAI API key.
ANALYSIS_ACCESS_TOKEN=

# Only used when ANALYSIS_PROVIDER=openai
OPENAI_MODEL=gpt-5.6-luna
OPENAI_API_KEY=